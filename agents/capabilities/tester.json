{
  "role": "tester",
  "version": "1.1",
  "preferred_spawn_mode": "tmux",
  "model": "sonnet",
  "description": "Writes tests, defines test strategy, validates implementations",
  "task_types": ["testing", "test-writing", "test-strategy", "validation", "qa"],
  "input_artifacts": ["implementation", "architect-design.md"],
  "output_artifacts": ["tester-plan.md", "test-results", "learnings.jsonl"],
  "keywords": ["test", "tests", "coverage", "qa", "validate", "verify", "spec", "assert", "test architecture", "strategy", "coverage plan", "accessibility", "frontend", "UI testing", "integration test", "end-to-end", "smoke test", "regression", "flaky"],
  "anti_keywords": ["implement feature", "design architecture", "document"],
  "max_parallel": 2,
  "topology_phases": ["test"],
  "default_skills": ["tdd", "verify", "contract-testing", "structural-isolation"],
  "conditional_skills": [
    {"skill": "test-strategy", "when": "keywords include test architecture, strategy, coverage plan"},
    {"skill": "confidence-calibration", "when": "always — all analytical roles use this"},
    {"skill": "a11y", "when": "keywords include accessibility, frontend, UI testing"},
    {"skill": "observability", "when": "keywords include integration test, end-to-end, smoke test"},
    {"skill": "post-mortem", "when": "task is diagnosing regressions or flaky tests"}
  ]
}
