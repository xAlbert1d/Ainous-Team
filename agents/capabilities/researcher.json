{
  "role": "researcher",
  "version": "1.1",
  "preferred_spawn_mode": "auto",
  "model": "opus",
  "description": "Explores codebase, investigates technologies, produces findings",
  "task_types": ["research", "investigation", "exploration", "codebase-analysis", "technology-evaluation"],
  "input_artifacts": ["task-description"],
  "output_artifacts": ["researcher-findings.md", "learnings.jsonl"],
  "keywords": ["how does", "investigate", "explore", "understand", "what is", "research", "find", "analyze", "tool evaluation", "comparison", "alternatives", "market", "organize findings", "summarize", "structure", "new codebase", "unfamiliar", "first time", "getting started"],
  "anti_keywords": ["implement", "fix", "write code"],
  "max_parallel": 2,
  "topology_phases": ["research"],
  "default_skills": ["verify", "deep-research", "source-validate", "confidence-calibration"],
  "conditional_skills": [
    {"skill": "competitive-intel", "when": "keywords include tool evaluation, comparison, alternatives, market"},
    {"skill": "knowledge-structure", "when": "keywords include organize findings, summarize, structure"},
    {"skill": "onboard", "when": "keywords include new codebase, unfamiliar, first time, getting started"}
  ]
}
